# Development Supabase project only.
# Never point this at a production project or real customer data.
#
# Copy this file to .env.local and fill in real values from your
# development Supabase project's API settings. Do not commit .env.local.

NEXT_PUBLIC_SUPABASE_URL=https://your-dev-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=placeholder-anon-key
SUPABASE_SERVICE_ROLE_KEY=placeholder-service-role-key

# Google Cloud API key with the PageSpeed Insights API enabled.
# Server-only — never exposed to the browser.
GOOGLE_PAGESPEED_API_KEY=placeholder-pagespeed-api-key

# The following are not used yet (added in later phases) and are listed
# here only so the eventual shape of the config is visible up front:
# GOOGLE_PLACES_API_KEY=
# APIFY_API_TOKEN=
# MAKE_WEBHOOK_SECRET=
